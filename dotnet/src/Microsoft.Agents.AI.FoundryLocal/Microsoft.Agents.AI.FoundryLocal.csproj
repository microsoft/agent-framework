<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Foundry Local SDK requires net8.0+ — use core TFMs only (no netstandard2.0/net472) -->
    <TargetFrameworks>$(TargetFrameworksCore)</TargetFrameworks>
    <!-- The Foundry Local SDK includes native binaries that require a runtime identifier -->
    <RuntimeIdentifiers>win-x64;win-arm64;linux-x64;linux-arm64;osx-arm64</RuntimeIdentifiers>
    <IsReleased>false</IsReleased>
    <InjectSharedThrow>true</InjectSharedThrow>
    <NoWarn>$(NoWarn);OPENAI001</NoWarn>
  </PropertyGroup>

  <Import Project="$(RepoRoot)/dotnet/nuget/nuget-package.props" />

  <!-- Disable package validation baseline until the first release under the new package name -->
  <PropertyGroup>
    <PackageValidationBaselineVersion />
    <EnablePackageValidation>false</EnablePackageValidation>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AI.Foundry.Local" />
    <PackageReference Include="Microsoft.Extensions.AI" />
    <PackageReference Include="Microsoft.Extensions.AI.OpenAI" />
    <PackageReference Include="OpenAI" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Microsoft.Agents.AI\Microsoft.Agents.AI.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <!-- NuGet Package Settings -->
    <Title>Microsoft Agent Framework for Foundry Local</Title>
    <Description>Provides Microsoft Agent Framework support for AI Foundry Local (on-device model inference).</Description>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Microsoft.Agents.AI.FoundryLocal.UnitTests" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
  </ItemGroup>

</Project>
