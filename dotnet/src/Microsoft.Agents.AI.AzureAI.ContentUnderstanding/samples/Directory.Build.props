<Project>

  <!--
    These samples live under the package directory (mirroring the Python
    azure-contentunderstanding package layout) instead of the shared dotnet/samples
    tree. This props file:
      * re-establishes the sample build conventions the projects would otherwise
        inherit from dotnet/samples/Directory.Build.props, and
      * shadows the parent src/Directory.Build.props so that library-only
        conventions (ReferenceTrimmer, packaging) do not apply to these
        executable sample projects.
    Importing dotnet/Directory.Build.props (not src/) keeps these in line with the
    rest of the repo's samples.
  -->
  <Import Project="..\..\..\Directory.Build.props" />

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsAotCompatible>false</IsAotCompatible>
    <UserSecretsId>5ee045b0-aea3-4f08-8d31-32d1a6f8fed0</UserSecretsId>
    <NoWarn>$(NoWarn);MAAI001</NoWarn>
  </PropertyGroup>

  <!-- Alias `Environment` to the sample helper that prompts for missing settings. -->
  <ItemGroup>
    <Using Include="SampleHelpers.SampleEnvironment" Alias="Environment" />
  </ItemGroup>

  <!-- Shared sample helpers (SampleEnvironment, etc.) compiled into each sample. -->
  <ItemGroup>
    <Compile Include="$(MSBuildThisFileDirectory)..\..\Shared\Demos\*.cs" LinkBase="" Visible="false" />
  </ItemGroup>

</Project>
