@inherits LayoutComponentBase
@inject LanguageService LangService
@inject IJSRuntime JS

<div class="layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-logo">MAF .NET</span>
            <span class="sidebar-subtitle">Tutorial</span>
        </div>
        <NavMenu />
        <div class="sidebar-footer">
            <LanguageSwitcher />
        </div>
    </aside>
    <main class="content">
        <article class="chapter-body">
            @Body
        </article>
    </main>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var stored = await JS.InvokeAsync<string>("getStoredLanguage");
            if (stored != LangService.CurrentCode)
            {
                LangService.SetLanguage(stored);
                StateHasChanged();
            }
        }
    }
}
