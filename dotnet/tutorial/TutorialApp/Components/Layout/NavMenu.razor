@implements IDisposable
@inject ChapterService ChapterService
@inject LanguageService LangService
@inject NavigationManager Nav

<nav class="nav-menu">
    @foreach (var chapter in ChapterService.GetChapters(LangService.CurrentCode))
    {
        var href = $"/chapter/{chapter.Slug}";
        var isActive = Nav.Uri.EndsWith(href, StringComparison.OrdinalIgnoreCase);
        <a href="@href" class="nav-item @(isActive ? "active" : "")">
            <span class="nav-number">@chapter.Order.ToString("D2")</span>
            <span class="nav-title">@chapter.Title</span>
        </a>
    }
</nav>

@code {
    protected override void OnInitialized()
        => LangService.OnChanged += OnLanguageChanged;

    private void OnLanguageChanged(object? sender, EventArgs e)
        => InvokeAsync(StateHasChanged);

    public void Dispose()
        => LangService.OnChanged -= OnLanguageChanged;
}
